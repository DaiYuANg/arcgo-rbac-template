## Server
HTTP_ADDR=:8080

## Database
# sqlite | mysql | postgres
DB_DRIVER=sqlite
DB_DSN=file:rbac.db?_pragma=busy_timeout(5000)

## Auth (JWT)
JWT_SECRET=dev-secret-change-me
JWT_ISSUER=arcgo-rbac-template
JWT_AUDIENCE=arcgo
ACCESS_TOKEN_TTL=30m
# refresh token TTL (cookie)
REFRESH_TOKEN_TTL=168h
ALLOW_INSECURE_DEV=true

## Auth sources (login)
# comma-separated: root,db
AUTH_SOURCES=root,db
AUTH_ROOT_USERNAME=root
AUTH_ROOT_PASSWORD=root
AUTH_LOGIN_RATE_LIMIT=20
AUTH_LOGIN_RATE_WINDOW=1m
AUTH_REFRESH_RATE_LIMIT=60
AUTH_REFRESH_RATE_WINDOW=1m

## KVX (Valkey/Redis) - optional distributed cache
KV_ENABLED=false
# valkey | redis
KV_DRIVER=valkey
KV_ADDR=127.0.0.1:6379
KV_PASSWORD=
KV_DB=0
KV_PREFIX=arcgo:
KV_DEFAULT_TTL=30s

## RBAC bootstrap
BOOTSTRAP_ADMIN_USER_ID=admin

